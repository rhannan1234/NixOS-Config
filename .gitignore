```
# Nix-specific ignores
.result
*.drv
*.nixpac
.nixd/
.nix-gc-symlinks/
.nix-*
!*.nix  # Don't ignore .nix files themselves

# Dependencies
.npm/
.node_modules/
.yarn/
.bower_components/

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Environment
.env
.env.local
.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# Build artifacts
dist/
build/
target/
*.o
*.obj
*.out

# Python (if applicable)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.log
.git/
.mypy_cache/
.pytest_cache/
.hypothesis/

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
