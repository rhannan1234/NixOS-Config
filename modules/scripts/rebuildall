#!/usr/bin/env bash
set -euo pipefail

# ✅ Hardcoded path to your NixOS config (change if needed)
CONFIG_DIR="$HOME/NixOS-Config"

if [ ! -d "$CONFIG_DIR" ]; then
    echo "❌ Error: Config directory not found at $CONFIG_DIR"
    exit 1
fi

cd "$CONFIG_DIR"

# Parse arguments (Default to WorkStation)
HOST="${1:-WorkStation}"
MESSAGE="${2:-auto-commit: $(date '+%Y-%m-%d %H:%M:%S')}"

echo "📂 Config Directory: $CONFIG_DIR"
echo "🎯 Target Host: $HOST"

# Git Add
echo "🍎 Staging changes..."
git add .

# Git Commit (Only if there are changes)
if ! git diff --quiet || ! git diff --cached --quiet; then
    echo "💾 Committing changes..."
    git commit -m "$MESSAGE"
else
    echo "⚠️  No changes detected, skipping commit."
fi

# NixOS Rebuild
echo "🔨 Rebuilding NixOS..."
sudo nixos-rebuild switch --flake .#$HOST

echo "✅ Done!"