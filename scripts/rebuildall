#!/usr/bin/env bash
set -euo pipefail

# Find the git root of your NixOS config
CONFIG_DIR="$(git rev-parse --show-toplevel 2>/dev/null)" || {
    echo "❌ Error: Not inside your NixOS-Config git repository"
    exit 1
}

cd "$CONFIG_DIR"

# Parse arguments (Default to WorkStation)
HOST="${1:-WorkStation}"
MESSAGE="${2:-auto-commit: $(date '+%Y-%m-%d %H:%M:%S')}"

echo "📂 Config Directory: $CONFIG_DIR"
echo "🎯 Target Host: $HOST"

# Git Add
echo "🍎 Staging changes..."
git add .

# Git Commit (Only if there are changes)
if ! git diff --quiet || ! git diff --cached --quiet; then
    echo "💾 Committing changes..."
    git commit -m "$MESSAGE"
else
    echo "⚠️  No changes detected, skipping commit."
fi

# NixOS Rebuild
echo "🔨 Rebuilding NixOS..."
sudo nixos-rebuild switch --flake .#$HOST

echo "✅ Done!"
